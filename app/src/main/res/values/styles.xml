<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ========== Стили для круглых аватарок ========== -->
    <style name="CircleImageView">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- ========== Стили для текста ========== -->

    <style name="TextAppearance.Whisper.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Whisper.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Whisper.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="TextAppearance.Whisper.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/grey_3</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="TextAppearance.Whisper.BodySmall" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/grey_3</item>
        <item name="android:textSize">12sp</item>
    </style>

    <!-- Стиль для цифры "8" в заголовке -->
    <style name="TitleEight">
        <item name="android:textColor">@color/primary_pink</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Стиль для имени пользователя -->
    <style name="UserName">
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Стиль для вторичного текста (статус, время) -->
    <style name="TextSecondary">
        <item name="android:textColor">@color/grey_3</item>
        <item name="android:textSize">14sp</item>
    </style>

    <!-- Стиль для пунктов меню -->
    <style name="MenuItemText">
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">16sp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingStart">16dp</item>
    </style>

    <!-- ========== Стили для кнопок ========== -->

    <!-- Основная розовая кнопка -->
    <style name="PrimaryButton" parent="Widget.Material3.Button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="backgroundTint">@color/primary_pink</item>
        <item name="cornerRadius">28dp</item>
    </style>

    <!-- Кнопка выхода -->
    <style name="LogoutButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/primary_pink</item>
        <item name="android:gravity">center</item>
    </style>

    <!-- ========== Стили для полей ввода ========== -->

    <style name="OutlinedEditText" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/grey_3</item>
        <item name="hintTextColor">@color/grey_3</item>
    </style>

    <!-- ========== Стили для поиска ========== -->

    <style name="SearchViewStyle" parent="Widget.AppCompat.SearchView">
        <item name="android:background">@drawable/search_background</item>
        <item name="android:queryHint">Поиск...</item>
    </style>

    <style name="AppSearchView" parent="Widget.AppCompat.SearchView">
        <item name="queryBackground">@android:color/transparent</item>
        <item name="submitBackground">@android:color/transparent</item>
        <item name="searchIcon">@null</item>
        <item name="android:editTextColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/grey_3</item>
    </style>

</resources>