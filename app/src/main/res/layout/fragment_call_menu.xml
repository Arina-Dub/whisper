<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <!-- Контейнер для Jitsi View -->
    <FrameLayout
        android:id="@+id/jitsiContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Ваш кастомный интерфейс поверх Jitsi -->
    <LinearLayout
        android:id="@+id/layoutOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/chats_background_gradient"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/textViewCallStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:gravity="center"
            android:text="@string/calling"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <Space android:layout_width="match_parent" android:layout_height="40dp" />

        <ImageView
            android:id="@+id/imageViewCallerAvatar"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center"
            android:src="@drawable/profile" />

        <Space android:layout_width="match_parent" android:layout_height="24dp" />

        <TextView
            android:id="@+id/textViewCallerName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/user_nickname"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textViewCallDuration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="00:00"
            android:textColor="@color/text_primary"
            android:textSize="18sp" />

        <Space android:layout_width="match_parent" android:layout_weight="1" android:layout_height="0dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <ImageButton
                    android:id="@+id/buttonSpeaker"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/ellipse2"
                    android:padding="16dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/volume"
                    app:tint="@color/text_primary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/speaker"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <ImageButton
                    android:id="@+id/buttonVideo"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/ellipse2"
                    android:padding="16dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/camera"
                    app:tint="@color/text_primary" />
                <TextView
                    android:id="@+id/textViewVideo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/video"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <ImageButton
                    android:id="@+id/buttonMute"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/ellipse2"
                    android:padding="16dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/microphone"
                    app:tint="@color/text_primary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/microphone"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <ImageButton
                    android:id="@+id/buttonEndCall"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/ellipse1"
                    android:padding="16dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/phone1" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/end_call"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</FrameLayout>
